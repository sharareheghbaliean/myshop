# Dependency directories (پوشه ماژول‌های نود که نباید آپلود شود)
node_modules/
jspm_packages/
web_modules/

# Logs (لاگ‌های سیستم و خطاها)
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# Runtime data (فایل‌های موقت زمان اجرا)
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt & Gulp transient files
.grunt
.lock-wscript

# Compiled binary files (فایل‌های باینری کامپایل شده)
build/Release

# Dependency directories for TypeScript
prebuilds

# Output directory for TypeScript compiler
dist/
out/

# IDEs and editors (فایل‌های تنظیمات ادیتورها)
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Operating System Files (فایل‌های سیستمی ویندوز و مک)
.DS_Store
Thumbs.db

# Environment variables and secrets (بسیار مهم: متغیرهای محیطی و فایل‌های حاوی رمز)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

